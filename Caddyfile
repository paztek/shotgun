:8080 {
    root * /srv
    encode gzip
    try_files {path} /index.html
    file_server

    header {
        Cache-Control "public, max-age=31536000, immutable"
    }

    @html path *.html
    header @html Cache-Control "no-cache"

    @sw path /sw.js /workbox-*.js
    header @sw Cache-Control "no-cache"
}
